# Copy this file to .env and fill in real values. .env is gitignored.
# See fintech_coding_guidelines.md §5 — keys never touch the repo.

# Kalshi (https://kalshi.com — API uses an access key ID + RSA private key file)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# Polymarket read-only endpoints need no key — nothing required for M1.

# Later milestones (leave empty until needed):
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# ALPACA_PAPER=true
